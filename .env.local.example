# Sanity — créer le projet sur sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token_here

# Brevo — créer un compte sur brevo.com (gratuit jusqu'à 300 emails/jour)
BREVO_API_KEY=your_brevo_api_key_here

# Email de notification (celui de Nora)
CONTACT_EMAIL=contact@noraevents.fr

# Secret pour le webhook Sanity → revalidation ISR
# Générer avec: openssl rand -hex 32
REVALIDATE_SECRET=your_random_secret_here
